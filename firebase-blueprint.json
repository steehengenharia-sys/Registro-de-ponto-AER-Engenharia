{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin_master", "admin", "funcionario"] },
        "role_name": { "type": "string" },
        "phone": { "type": "string" },
        "cargo": { "type": "string" },
        "telefone": { "type": "string" },
        "valor_diaria": { "type": "number" },
        "status": { "type": "string", "enum": ["ativo", "inativo"] }
      },
      "required": ["id", "name", "username", "role"]
    },
    "Work": {
      "title": "Work",
      "description": "Construction site or work location",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "radius": { "type": "number" }
      },
      "required": ["id", "name", "city", "address"]
    },
    "Point": {
      "title": "Point",
      "description": "Time clock record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "funcionario_id": { "type": "string" },
        "user_name": { "type": "string" },
        "date": { "type": "string" },
        "work_id": { "type": "string" },
        "entrada1": { "type": "string" },
        "saida1": { "type": "string" },
        "entrada2": { "type": "string" },
        "saida2": { "type": "string" },
        "entrada1_lat": { "type": "number" },
        "entrada1_lng": { "type": "number" },
        "entrada1_acc": { "type": "number" },
        "entrada1_address": { "type": "string" },
        "entrada1_dist": { "type": "number" },
        "entrada1_status": { "type": "string" },
        "entrada1_suspeito": { "type": "number" },
        "entrada1_gps_status": { "type": "string" },
        "saida1_lat": { "type": "number" },
        "saida1_lng": { "type": "number" },
        "saida1_acc": { "type": "number" },
        "saida1_address": { "type": "string" },
        "saida1_dist": { "type": "number" },
        "saida1_status": { "type": "string" },
        "saida1_suspeito": { "type": "number" },
        "saida1_gps_status": { "type": "string" },
        "entrada2_lat": { "type": "number" },
        "entrada2_lng": { "type": "number" },
        "entrada2_acc": { "type": "number" },
        "entrada2_address": { "type": "string" },
        "entrada2_dist": { "type": "number" },
        "entrada2_status": { "type": "string" },
        "entrada2_suspeito": { "type": "number" },
        "entrada2_gps_status": { "type": "string" },
        "saida2_lat": { "type": "number" },
        "saida2_lng": { "type": "number" },
        "saida2_acc": { "type": "number" },
        "saida2_address": { "type": "string" },
        "saida2_dist": { "type": "number" },
        "saida2_status": { "type": "string" },
        "saida2_suspeito": { "type": "number" },
        "saida2_gps_status": { "type": "string" },
        "total_hours": { "type": "number" },
        "obs": { "type": "string" },
        "editado_manual": { "type": "number" },
        "encerrado": { "type": "number" }
      },
      "required": ["id", "user_id", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/works/{workId}": {
      "schema": { "$ref": "#/entities/Work" },
      "description": "Work locations"
    },
    "/points/{pointId}": {
      "schema": { "$ref": "#/entities/Point" },
      "description": "Time clock records"
    }
  }
}
